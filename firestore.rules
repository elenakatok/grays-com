rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /game_instances/{instanceId}/participants/{participantId} {
      // Students can read their own record.
      allow read: if request.auth != null && request.auth.uid == participantId;

      // Students can update only their own prep answer fields.
      // affectedKeys().hasOnly(...) ensures no other field (role, score,
      // group_id, etc.) can be changed by a direct client write.
      // create and delete are not covered by any rule, so they remain denied.
      allow update: if request.auth != null
        && request.auth.uid == participantId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['prep_first_topic', 'prep_estimated_other_price',
                       'prep_question_for_other', 'prep_planned_first_offer',
                       'prep_planned_offer_reason']);
    }

    // role_counts is an internal balancing counter — backend only.
    match /game_instances/{instanceId}/role_counts/{doc} {
      allow read, write: if false;
    }

    // Game config (PDF URLs, reservation prices, etc.) is backend-only.
    // Clients get only their role's private URL via the getInfoUrls Cloud Function,
    // which never exposes the other role's URL.
    match /game_instances/{instanceId}/config/{doc} {
      allow read, write: if false;
    }

    // Default deny for everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
