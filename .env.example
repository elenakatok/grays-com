# Firebase Web SDK config (VITE_ prefix makes these available in the browser bundle)
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=grays-mygames-live.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=grays-mygames-live
VITE_FIREBASE_STORAGE_BUCKET=grays-mygames-live.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id-here
VITE_FIREBASE_APP_ID=your-app-id-here
VITE_FIREBASE_DATABASE_URL=https://grays-mygames-live-default-rtdb.firebaseio.com

# Classroom integration — Cloud Functions only (never expose to browser)
# The classroom signs launch JWTs with RS256, key id "classroom-v1".
# The public key is baked into functions/src/engine/classroomPublicKey.ts —
# no env var is required for it. This entry documents the current key for
# reference and for any env-var-based override approach in the future.
# Format: single line with literal \n between PEM lines (dotenv constraint).
CLASSROOM_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA2lO4IdqNX7pzR67cp9c/\nckt4SxB9vlQcro4fldBLc/bxQgKKC+J2wpeqdk4TugKTV76WbgsKMpvulBd4ELHl\nOjhUSHk3jYlB9sprM9QZ7H5G+DFJOpePdOGRCfuD8rK4oLB5q23XlYc6tgSanb9c\nXbjFFA/lQWm8eVcXC2GwJbqfmFjJzj7gZ4HSr9W0nDRo1vJFB1uUODuvpMv8tu/2\nPplHhvqC0/LHI/BF9uXrR/rK5fz5LdcG7cJL82hG7tA1CJKWoZsGf/fIPV2riYyC\naPAJYHdE0b+s/owlFxNodLVzyuqyT9jg/mcJrngOj9cFMcUvyFRu2i+8+x/wDeqF\nJQIDAQAB\n-----END PUBLIC KEY-----

# Shared secret the game uses to authenticate result callbacks to the classroom.
# Set in classroom game-registry.json (callback_secret) AND here.
# Set via: firebase functions:secrets:set CLASSROOM_CALLBACK_SECRET
CLASSROOM_CALLBACK_SECRET=replace-with-shared-secret

# Classroom endpoint that receives GameResult records
CLASSROOM_CALLBACK_URL=https://classroom.mygames.live/api/game-results
